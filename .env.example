PORT=3001
HOST=0.0.0.0
MONGODB_URI=<your-mongodb-uri>
NODE_ENV=dev
LOG_LEVEL=info
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# Alert algorithm: kadane | zscore | both
ALERT_ALGORITHM=zscore

# Minimum minutes between broadcast alerts (0 = no cooldown)
ALERT_COOLDOWN_MINUTES=60

# Cron schedule for rate polling (default: every 30 minutes)
RATE_CRONJOB_EXPRESSION=*/30 * * * *

# Cron schedule for daily summary (default: noon Bolivia time)
DAILY_SUMMARY_CRON=0 12 * * *

# Telegram chat ID of the admin user (for /stats command)
TELEGRAM_ADMIN_CHAT_ID=

# Kadane algorithm
RATE_WINDOW_SIZE=6
RATE_THRESHOLD=0.25

# Z-score algorithm
RATE_ZSCORE_WINDOW_SIZE=20
RATE_ZSCORE_THRESHOLD=2.0
